    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.0",
    "replace": "^1.2.2",
    "rimraf": "^6.0.1",
    "semver": "^7.7.2",
    "shx": "^0.4.0",
    "ts-pnp": "^1.2.0",
    "vitest": "^3.2.4"
