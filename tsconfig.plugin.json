{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["esnext", "esnext.asynciterable"],
    "strict": true,
    "declaration": true,
    "allowJs": true,
    "downlevelIteration": true,
    "importHelpers": true,
    "skipLibCheck": true
  }
}
