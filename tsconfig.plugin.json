{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ESNext", "ESNext.AsyncIterable"],
    "strict": true,
    "declaration": true,
    "allowJs": true,
    "downlevelIteration": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}
