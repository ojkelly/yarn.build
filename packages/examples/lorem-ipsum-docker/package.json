{
  "name": "@internal/lorem-ipsum-docker",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/src/index.js",
  "exports": {
    ".": {
      "types": [
        "./dist/src/index.d.ts"
      ],
      "default": "./dist/src/index.js"
    },
    "./*": {
      "types": [
        "./dist/src/*.d.ts"
      ],
      "default": "./dist/src/*.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "start": "node dist/src/index.js",
    "build": "tsc",
    "test": "vitest run",
    "dev": "ts-node ./src/index.ts"
  },
  "dependencies": {
    "@internal/phrase-lorem-ipsum": "workspace:^",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "ts-node": "^10.9.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "yarn.build": {
    "input": ".",
    "output": "dist"
  }
}
